name: Update VPN Configs

on:
  schedule:
    - cron: '0 */6 * * *'   # Запуск каждые 6 часов
  workflow_dispatch:         # Возможность запуска вручную

jobs:
  update:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      
      - name: Fetch and update configs
        run: |
          # URL источников, откуда вы будете брать конфиги
          SOURCES=(
            "https://github.com/AvenCores/goida-vpn-configs/raw/refs/heads/main/githubmirror/23.txt"
            "https://github.com/AvenCores/goida-vpn-configs/raw/refs/heads/main/githubmirror/25.txt"
          )
          
          # Очищаем файл перед записью
          > svoboda-configs.txt
          
          # Скачиваем и объединяем конфиги
          for url in "${SOURCES[@]}"; do
            curl -s "$url" >> svoboda-configs.txt
            echo "" >> svoboda-configs.txt  # Добавляем разделитель
          done
          
          # Удаляем дубликаты и пустые строки
          sort -u svoboda-configs.txt -o svoboda-configs.txt
          sed -i '/^$/d' svoboda-configs.txt
      
      - name: Commit and push if changed
        run: |
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add svoboda-configs.txt
          git diff --staged --quiet || git commit -m "Auto-update configs"
          git push
